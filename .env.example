# Discord bot
# Application settings: https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Voice gateway and capture
VOICE_CORE_URL=http://127.0.0.1:8765
VOICE_CORE_TIMEOUT_MS=600000
DISCORD_SILENCE_MS=850
DISCORD_MIN_VOICE_RMS=120
DISCORD_MIN_VOICE_PEAK=600
MAX_UTTERANCE_SECONDS=30

# Wake word detection
WAKE_WORD=омни
WAKE_WORD_ALIASES=помни,вомни,омли,омне,о мне,о мни,амни,умни,омний,омник,умник
HOTWORD_CHECK_INTERVAL_MS=650
HOTWORD_MIN_AUDIO_MS=600
HOTWORD_TIMEOUT_MS=5000
HOTWORD_MODEL=small
HOTWORD_DEVICE=cpu
HOTWORD_COMPUTE_TYPE=int8

# Speech recognition
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=ru
WHISPER_BEAM_SIZE=2
WHISPER_SPEECH_GATE=true
WHISPER_SPEECH_GATE_THRESHOLD=0.5
WHISPER_MIN_SPEECH_MS=180
WHISPER_LEADING_SILENCE_MS=400
RECOGNITION_PENDING_PER_SPEAKER=2

# Dialogue and memory
STOP_PHRASES=стоп,стопэ,стопе,хватит,хвати,фатит,достаточно,харе,харэ,заканчивай,заканчиваем,закончи,закончить,закончим,закончили,заверши,завершить,заверши диалог,закрой диалог,прекрати,прекращай,прекрати слушать,перестань слушать,не слушай,замолчи,молчи,можешь отключаться,отключайся,остановись,останови диалог,до свидания,пока
FOLLOWUP_SECONDS=30
FOLLOWUP_MIN_CHARS=4
FOLLOWUP_IGNORE_PHRASES=да,ага,угу,нет,ок,окей,ладно,понятно
MAX_HISTORY_TURNS=8
USER_MEMORY_DB_PATH=data/user-memory.sqlite3

# LM Studio
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=local-model
LMSTUDIO_TEMPERATURE=0.6
LMSTUDIO_MAX_TOKENS=220
LMSTUDIO_TIMEOUT_SECONDS=180
LMSTUDIO_PROGRESS_INTERVAL_SECONDS=2

# Text-to-speech and audio cues
TTS_DEFAULT_VOICE=silero:eugene
TTS_DEFAULT_EFFECT=none
AUDIO_CUE_VOLUME=0.045
PIPER_MODEL_PATH=models/ru_RU-ruslan-medium.onnx
PIPER_LENGTH_SCALE=1.18
PIPER_SENTENCE_SILENCE_MS=320
SILERO_PUT_ACCENT=true
SILERO_PUT_YO=true
SILERO_SENTENCE_SILENCE_MS=220
TTS_ROBOT_PITCH_SEMITONES=-1.5
TTS_ROBOT_HARMONY_VOLUME=0.10
TTS_ROBOT_MODULATION_HZ=35
TTS_ROBOT_MODULATION_DEPTH=0.07
TTS_ROBOT_REVERB=0.06
